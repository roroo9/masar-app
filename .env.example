# ── Backend (Railway) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — Railway injects DATABASE_URL automatically when you add the plugin
# For local dev, set individual vars below instead
DATABASE_URL=postgresql://masar_user:masar_pass@localhost:5432/masar

# JWT — generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-secret

# Comma-separated allowed frontend origins (add your Vercel URL here)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set in Vercel → Project → Settings → Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:8000

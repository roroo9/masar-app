# ── Backend (Railway) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — Railway provides DATABASE_URL automatically when you add a DB plugin
DATABASE_URL=postgresql://masar_user:masar_pass@localhost:5432/masar

# Comma-separated list of allowed frontend origins
# Set to your Vercel URL after first deployment, e.g.:
#   ALLOWED_ORIGINS=https://masar-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set this in Vercel dashboard → Project → Settings → Environment Variables
# Value: your Railway backend URL, e.g. https://masar-api-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
